# Backend Environment Variables Template
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=5000

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/virtualassistant
# For MongoDB Atlas, use: mongodb+srv://username:password@cluster.mongodb.net/dbname

# Google Gemini API
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=YOUR_GEMINI_API_KEY

# JWT Secret Key for user authentication
JWT_SECRET=your_super_secret_jwt_key_change_this

# Cloudinary Configuration (for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173
